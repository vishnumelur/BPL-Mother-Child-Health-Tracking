# Neon Postgres — two connection strings, both from the same project.
# Get them from console.neon.tech → your project → Connection Details.

# Pooled connection (used by the Next.js app at runtime)
# Note: HOST has "-pooler" in it
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Unpooled / direct connection (used by drizzle-kit push, migrations, seed scripts)
# Note: same as above but WITHOUT "-pooler" in the host
DATABASE_URL_UNPOOLED="postgresql://USER:PASS@HOST.REGION.aws.neon.tech/DB?sslmode=require"
